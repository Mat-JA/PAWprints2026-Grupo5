{% extends 'layouts/main.twig' %}

{% block title %}PawPrints - {{ libro.desc_corta }}{% endblock %}

{% block schema %}
  {{ parent() }}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Book",
    "name": {{ libro.titulo | json_encode | raw }},
    "isbn": {{ libro.isbn | json_encode | raw }},
    "description": {{ libro.descripcion | json_encode | raw }},
    "image": {{ libro.imagen_url | json_encode | raw }},
    "datePublished": {{ libro.fecha_pub | json_encode | raw }},
    {% if autores is defined and autores|length > 0 %}
    "author": [
      {% for autor in autores %}
      {
        "@type": "Person",
        "name": {{ autor.nombre | json_encode | raw }}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ],
    {% endif %}
    "offers": {
      "@type": "Offer",
      "price": "{{ libro.precio }}",
      "priceCurrency": "ARS",
      "seller": {
        "@type": "BookStore",
        "name": "PAWPrints"
      },
      "availability": "https://schema.org/{{ libro.stock > 0 ? 'InStock' : 'OutOfStock' }}"
    }
  }
  </script>
{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/detalle_libro.css">
{% endblock %}

{% block main_attrs %}class="detalle-main"{% endblock %}

{% block content %}
  <article class="detalle-libro" itemscope itemtype="https://schema.org/Book">
    <div class="datos-libro">
      <div class="portada-libro">
        <img
          itemprop="image"
          src="{{ libro.imagen_url }}"
          alt="Portada del libro"
          class="imgPortada"
        >
      </div>

      <div class="texto-datos-libro">
        <h1 itemprop="name">{{ libro.titulo }}</h1>

        <p class="libro-desc-corta">{{ libro.desc_corta }}</p>

        {% if libro.autores is defined and libro.autores is not empty %}
          <p class="libro-autor">
            {% for autor in libro.autores %}
              <span itemprop="author" itemscope itemtype="https://schema.org/Person">
                <span itemprop="name">{{ autor.nombre }}</span>
              </span>{% if not loop.last %}, {% endif %}
            {% endfor %}
          </p>
        {% endif %}

        <p class="libro-isbn">
          <strong>ISBN:</strong>
          <span itemprop="isbn">{{ libro.isbn }}</span>
        </p>

        <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="priceCurrency" content="ARS">
          <link itemprop="availability"
                href="https://schema.org/{{ libro.stock > 0 ? 'InStock' : 'OutOfStock' }}">

          <p class="libro-precio">
            Precio: $<span itemprop="price"
                           content="{{ libro.precio }}">{{ libro.precio|number_format(2, ',', '.') }}</span>
          </p>

          <p class="libro-stock">Stock: {{ libro.stock }}</p>

          <a href="/formularioCompra?id={{ libro.id }}" class="btn-comprar">Comprar</a>
        </div>

        <div itemprop="aggregateRating" itemscope itemtype="https://schema.org/AggregateRating">
          <p class="libro-puntuacion">
            Puntuación: ★
            <span itemprop="ratingValue">5</span>/<span itemprop="bestRating">5</span>
            <meta itemprop="ratingCount" content="1">
          </p>
        </div>
      </div>
    </div>

    <section class="descripcion-libro">
      <h2>Descripción</h2>
      <p itemprop="description">{{ libro.descripcion }}</p>
    </section>
  </article>

  <section class="comentarios">
    <h2>Comentarios</h2>
    <article class="opinion" itemprop="review" itemscope itemtype="https://schema.org/Review">
      <div class="opinion-datos">
        <p itemprop="author" itemscope itemtype="https://schema.org/Person">
          <span itemprop="name">Juan Apellido</span>
        </p>
        <p><time itemprop="datePublished" datetime="2024-01-01">dd/mm/aaaa</time></p>
        <div itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
          <p>Puntuación: <span itemprop="ratingValue">5</span>/<span itemprop="bestRating">5</span></p>
        </div>
      </div>
      <div class="opinion-texto">
        <p itemprop="reviewBody">Lorem ipsum dolor sit amet...</p>
      </div>
    </article>
  </section>
{% endblock %}