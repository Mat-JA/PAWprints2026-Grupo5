{% extends 'layouts/main.twig' %}

{% block title %}PawPrints - {{ libro.desc_corta }}{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/detalle_libro.css">
{% endblock %}

{% block main_attrs %}class="detalle-main"{% endblock %}

{% block content %}
  <article class="detalle-libro">
    <div class="datos-libro">
      <div class="portada-libro">
        <img
          src="{{ libro.imagen_url }}"
          alt="Portada del libro"
          class="imgPortada"
        >
      </div>

      <div class="texto-datos-libro">
        <h1>{{ libro.titulo }}</h1>

        <p class="libro-desc-corta">{{ libro.desc_corta }}</p>

        {% if libro.autores is defined and libro.autores is not empty %}
          <p class="libro-autor">
            {% for autor in libro.autores %}
              {{ autor.nombre }}{% if not loop.last %}, {% endif %}
            {% endfor %}
          </p>
        {% endif %}

        <p class="libro-isbn"><strong>ISBN:</strong> {{ libro.isbn }}</p>

        <p class="libro-precio">Precio: ${{ libro.precio|number_format(2, ',', '.') }}</p>

        <p class="libro-stock">Stock: {{ libro.stock }}</p>

        <a href="/formularioCompra?id={{ libro.id }}" class="btn-comprar">Comprar</a>

        <p class="libro-puntuacion">Puntuación: ★ 5/5</p>
      </div>
    </div>

    <section class="descripcion-libro">
      <h2>Descripción</h2>
      <p>{{ libro.descripcion }}</p>
    </section>
  </article>

  <section class="comentarios">
    <h2>Comentarios</h2>
    <article class="opinion">
      <div class="opinion-datos">
        <p>Juan Apellido</p>
        <p>dd/mm/aaaa</p>
        <p>Puntuación: 5/5</p>
      </div>
      <div class="opinion-texto">
        <p>Lorem ipsum dolor sit amet...</p>
      </div>
    </article>
  </section>
{% endblock %}