{% extends 'layouts/main.twig' %}

{% block title %}PawPrints - Catálogo{% endblock %}

{% block schema %}
  {{ parent() }}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Catálogo de libros – PAWPrints",
    "itemListElement": [
      {% for libro in librosSchema %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "item": {
          "@type": "Book",
          "name": {{ libro.titulo | json_encode | raw }},
          "isbn": {{ libro.isbn | json_encode | raw }},
          "description": {{ libro.desc_corta | json_encode | raw }},
          "image": {{ libro.imagen_url | json_encode | raw }},
          "url": "/libro?id={{ libro.id }}",
          "offers": {
            "@type": "Offer",
            "price": "{{ libro.precio }}",
            "priceCurrency": "ARS",
            "availability": "https://schema.org/{{ libro.stock > 0 ? 'InStock' : 'OutOfStock' }}"
          }
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/catalogo.css">
  <link rel="stylesheet" href="/assets/css/tarjeta_libro.css">
{% endblock %}

{% block scripts %}
  <script type="module" src="/assets/js/pages/Catalogo.js"></script>
{% endblock %}

{% block content %}
  <div class="cabecera-catalogo">
    <h2>Nuestros libros</h2>
    <a href="/catalogo/exportar" class="btn-filtro btn-csv">Descargar CSV</a>
  </div>

  <div class="contenido">
    <ul id="books-grid" class="grilla-libros"></ul>

    <div id="sentinel" style="display:none;"></div>
    <div id="loading-indicator" style="display:none;">Cargando más libros…</div>

    <aside>
      <button class="btn-toggle-filters" type="button">Filtros</button>
      <div class="filter-panel">
        <form id="filter-form">
          <fieldset>
            <legend>Precio</legend>
            <label>
              Mín:
              <input type="number" id="min-price" inputmode="decimal" placeholder="0">
            </label>
            <label>
              Máx:
              <input type="number" id="max-price" inputmode="decimal" placeholder="∞">
            </label>
          </fieldset>

          <fieldset>
            <legend>Ordenar</legend>
            <label>
              Campo:
              <select id="sort-field">
                <option value="titulo">Título</option>
                <option value="autor">Autor</option>
                <option value="precio">Precio</option>
              </select>
            </label>
            <label>
              Dirección:
              <select id="sort-dir">
                <option value="asc">Ascendente</option>
                <option value="desc">Descendente</option>
              </select>
            </label>
          </fieldset>
        </form>
      </div>
    </aside>
  </div>
{% endblock %}