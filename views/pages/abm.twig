{% extends 'layouts/main.twig' %}

{% block title %}PawPrints - ABM Libros{% endblock %}

{% block styles %}
  <link rel="stylesheet" href="/assets/css/imageDropzone.css">
  <link rel="stylesheet" href="/assets/css/abm.css">
{% endblock %}

{% block main_attrs %}class="abm-main"{% endblock %}

{% block content %}
  <div class="abm-header">
    <h1 class="abm-titulo">Administración de libros</h1>
    <button class="abm-btn-nuevo" id="btn-nuevo">+ Nuevo libro</button>
  </div>

  {% if app.request.get.exito is defined %}
    <div class="abm-alerta abm-alerta--exito">
      {% set msgs = {
        'creado':      '✅ Libro creado correctamente.',
        'actualizado': '✅ Libro actualizado correctamente.',
        'eliminado':   '✅ Libro eliminado correctamente.'
      } %}
      {{ msgs[app.request.get.exito] ?? '✅ Operación realizada.' }}
    </div>
  {% endif %}

  {% if app.request.get.error is defined %}
    <div class="abm-alerta abm-alerta--error">
      ❌ {{ app.request.get.error | e }}
    </div>
  {% endif %}

  <div class="abm-tabla-wrapper">
    <table class="abm-tabla">
      <thead>
        <tr>
          <th>Tapa</th>
          <th>Título</th>
          <th>Autor</th>
          <th>ISBN</th>
          <th>Precio</th>
          <th>Stock</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        {% for libro in libros %}
          <tr>
            <td>
              {% if libro.imagen_url %}
                <img src="{{ libro.imagen_url }}" alt="Tapa" class="abm-tabla-tapa">
              {% else %}
                <span class="abm-sin-imagen">Sin imagen</span>
              {% endif %}
            </td>
            <td>{{ libro.titulo }}</td>
            <td>
              {%- if libro.autores is defined and libro.autores is not empty -%}
                {%- for autor in libro.autores -%}
                  {{- autor.nombre -}}{% if not loop.last %}, {% endif %}
                {%- endfor -%}
              {%- else -%}
                <em>Sin autor</em>
              {%- endif -%}
            </td>
            <td>{{ libro.isbn }}</td>
            <td>${{ libro.precio|number_format(2, ',', '.') }}</td>
            <td>{{ libro.stock }}</td>
            <td>
              <button
                class="abm-btn-editar"
                data-libro="{{ libro|json_encode|e('html_attr') }}"
              >
                Editar
              </button>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="abm-panel" id="abm-panel" hidden>
    <div class="abm-panel-header">
      <h2 class="abm-panel-titulo" id="panel-titulo">Nuevo libro</h2>
      <button class="abm-panel-cerrar" id="btn-cerrar-panel" aria-label="Cerrar panel">✕</button>
    </div>

    <form method="post" action="/libros/abm/crear" enctype="multipart/form-data" class="abm-form" id="form-crear">
      {% include 'partials/abm_campos.twig' %}
      <div class="abm-form-actions">
        <input type="submit" value="Crear libro" class="bSubmit">
      </div>
    </form>

    <form method="post" action="/libros/abm/actualizar" enctype="multipart/form-data" class="abm-form" id="form-editar" hidden>
      <input type="hidden" name="id" id="edit-id">
      {% include 'partials/abm_campos.twig' %}
      <div class="abm-form-actions">
        <input type="submit" value="Guardar cambios" class="bSubmit">
        <button type="button" class="abm-btn-eliminar" id="btn-eliminar">Eliminar libro</button>
      </div>
    </form>

    <form method="post" action="/libros/abm/eliminar" id="form-eliminar" hidden>
      <input type="hidden" name="id" id="eliminar-id">
    </form>
  </div>

  <div class="abm-modal-overlay" id="modal-overlay" hidden>
    <div class="abm-modal" role="dialog" aria-labelledby="modal-titulo">
      <div class="abm-panel-header">
        <h2 class="abm-panel-titulo" id="modal-titulo">Nuevo autor</h2>
        <button class="abm-panel-cerrar" id="btn-cerrar-modal" aria-label="Cerrar">✕</button>
      </div>
      <form id="form-inline-autor" class="abm-form">
        <fieldset class="abm-fieldset">
          <label class="formulario-label abm-full">
            Nombre:
            <input type="text" name="nombre" class="abm-input" required maxlength="60">
          </label>
          <label class="formulario-label abm-full">
            Biografía (opcional):
            <textarea name="bio" class="abm-textarea" maxlength="250"></textarea>
          </label>
        </fieldset>
        <div class="abm-form-actions">
          <input type="submit" value="Crear autor y seleccionar" class="bSubmit" id="btn-inline-crear">
        </div>
      </form>
      <p id="inline-error" class="abm-campo-error" hidden></p>
    </div>
  </div>
{% endblock %}

{% block scripts %}
  <script src="/assets/js/imageDropzone.js"></script>
  <script src="/assets/js/abm.js"></script>
{% endblock %}